# Copy to .env for local runs (never commit the real .env).
# Message @BotFather on Telegram to create a bot and get a token.
# Message your new bot, then GET https://api.telegram.org/bot<token>/getUpdates
# to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Comma-separated list of AMC showtime "seats" URLs to watch.
# AMC_SHOWTIME_URLS=https://www.amctheatres.com/showtimes/143822184/seats
